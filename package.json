{
  "name": "adaptive-meal-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Adaptive Meal Planning Platform for Rwanda — AI-powered personalized meal recommendations",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter database prisma:generate",
    "db:push": "pnpm --filter database prisma:push",
    "db:migrate": "pnpm --filter database prisma:migrate",
    "db:studio": "pnpm --filter database prisma:studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "eslint": "^9.20.0",
    "typescript": "^5.7.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
