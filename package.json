{
  "name": "adaptive-meal-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Adaptive Meal Planning Platform for Rwanda — AI-powered personalized meal recommendations",
  "scripts": {
    "dev": "dotenv -e .env -- turbo run dev",
    "dev:api": "dotenv -e .env -- turbo run dev --filter=api",
    "dev:web": "dotenv -e .env -- turbo run dev --filter=web",
    "dev:mobile": "dotenv -e .env -- turbo run dev --filter=mobile",
    "build": "dotenv -e .env -- turbo run build",
    "lint": "dotenv -e .env -- turbo run lint",
    "test": "dotenv -e .env -- turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "start": "bash scripts/start.sh",
    "seed": "DATABASE_URL=\"postgresql://mealplan:mealplan_dev@localhost:5433/adaptive_meals?schema=public\" pnpm --filter database prisma:seed",
    "db:generate": "pnpm --filter database prisma:generate",
    "db:push": "pnpm --filter database prisma:push",
    "db:migrate": "pnpm --filter database prisma:migrate",
    "db:studio": "pnpm --filter database prisma:studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
