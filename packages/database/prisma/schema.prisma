// =============================================================================
// Prisma Schema — Adaptive Meal Planning Platform
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum CuisineType {
  RWANDAN
  EAST_AFRICAN
  AFRICAN
  INTERNATIONAL
  FUSION
}

enum Complexity {
  EASY
  MEDIUM
  HARD
}

enum BudgetLevel {
  LOW
  MEDIUM
  HIGH
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum CookingSkill {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum FeedbackType {
  LIKED
  DISLIKED
  TOO_EXPENSIVE
  TOO_DIFFICULT
  TOO_REPETITIVE
  TOO_TIME_CONSUMING
}

enum VideoSource {
  YOUTUBE
  TIKTOK
  ORIGINAL
}

enum AgeRange {
  UNDER_18
  AGE_18_25
  AGE_26_35
  AGE_36_45
  AGE_46_55
  OVER_55
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum LocalAvailability {
  COMMON
  SEASONAL
  RARE
  IMPORTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                  String         @id @default(cuid())
  clerkId             String         @unique
  email               String         @unique
  fullName            String
  ageRange            AgeRange?
  gender              Gender?
  householdSize       Int            @default(1)
  budgetLevel         BudgetLevel    @default(MEDIUM)
  activityLevel       ActivityLevel  @default(MODERATE)
  cookingSkill        CookingSkill   @default(INTERMEDIATE)
  dietaryPreferences  String[]       @default([])
  allergies           String[]       @default([])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  recommendations     Recommendation[]
  feedback            Feedback[]
  preferences         UserPreference[]
  healthMetrics       HealthMetric[]
  mealPlans           MealPlan[]
  shoppingLists       ShoppingList[]

  @@map("users")
}

model Meal {
  id                String          @id @default(cuid())
  title             String
  description       String
  preparationTime   Int             // minutes
  estimatedCost     Float           // RWF
  calories          Int
  cuisineType       CuisineType     @default(RWANDAN)
  complexity        Complexity      @default(MEDIUM)
  tags              String[]        @default([])
  imageUrl          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  images            MealImage[]
  ingredients       MealIngredient[]
  nutritionProfile  NutritionProfile?
  videos            VideoReference[]
  recommendations   Recommendation[]
  feedback          Feedback[]
  mealPlanEntries   MealPlanEntry[]

  @@map("meals")
}

model MealImage {
  id        String   @id @default(cuid())
  mealId    String
  url       String
  createdAt DateTime @default(now())

  meal      Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("meal_images")
}

model Ingredient {
  id                String            @id @default(cuid())
  name              String            @unique
  localAvailability LocalAvailability @default(COMMON)
  averageCost       Float             // RWF

  meals             MealIngredient[]
  shoppingListItems ShoppingListItem[]

  @@map("ingredients")
}

model MealIngredient {
  id           String     @id @default(cuid())
  mealId       String
  ingredientId String
  quantity     Float
  unit         String

  meal         Meal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([mealId, ingredientId])
  @@map("meal_ingredients")
}

model NutritionProfile {
  id       String  @id @default(cuid())
  mealId   String  @unique
  protein  Float   // grams
  carbs    Float
  fat      Float
  fiber    Float
  vitamins String? // JSON or text summary

  meal     Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("nutrition_profiles")
}

model VideoReference {
  id          String      @id @default(cuid())
  mealId      String
  url         String
  source      VideoSource @default(YOUTUBE)
  title       String
  creatorName String?

  meal        Meal        @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("video_references")
}

model Recommendation {
  id                  String   @id @default(cuid())
  userId              String
  mealId              String
  recommendationScore Float
  mealType            MealType
  createdAt           DateTime @default(now())

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal                Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("recommendations")
}

model Feedback {
  id           String       @id @default(cuid())
  userId       String
  mealId       String
  rating       Int          // 1-5
  feedbackType FeedbackType
  comment      String?
  createdAt    DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal         Meal         @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([userId, mealId])
  @@map("feedback")
}

model UserPreference {
  id              String @id @default(cuid())
  userId          String
  preferenceKey   String
  preferenceValue String

  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, preferenceKey])
  @@map("user_preferences")
}

model HealthMetric {
  id         String   @id @default(cuid())
  userId     String
  metricType String
  value      Float
  recordedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, metricType])
  @@map("health_metrics")
}

model MealPlan {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime // Monday of the plan week
  weekEnd   DateTime // Sunday of the plan week
  name      String   @default("Weekly Meal Plan")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   MealPlanEntry[]

  @@unique([userId, weekStart])
  @@map("meal_plans")
}

model MealPlanEntry {
  id        String   @id @default(cuid())
  mealPlanId String
  mealId    String
  mealType  MealType
  dayOfWeek Int      // 0=Sunday, 1=Monday ... 6=Saturday
  sortOrder Int      @default(0)

  mealPlan  MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  meal      Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("meal_plan_entries")
}

model ShoppingList {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Shopping List")
  weekStart DateTime?
  weekEnd   DateTime?
  totalCost Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ShoppingListItem[]

  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String        @id @default(cuid())
  shoppingListId String
  ingredientId   String?
  ingredientName String
  quantity       Float
  unit           String
  estimatedCost  Float         @default(0)
  isChecked      Boolean       @default(false)

  shoppingList   ShoppingList  @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  ingredient     Ingredient?   @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  @@map("shopping_list_items")
}
